# ============================================================
# AIVA .env.example — copy sang file .env tương ứng để dùng
# ============================================================

# ── aiva-telegram-bot/.env ──────────────────────────────────
TELEGRAM_BOT_TOKEN=<care_bot_token>
DIFY_API_KEY=<dify_app_key_for_care_chatflow>
DIFY_API_BASE_URL=http://host.docker.internal/v1
EXTERNAL_KNOWLEDGE_URL=http://host.docker.internal:8000
EXTERNAL_KB_API_KEY=sk-aiva-external-knowledge-secret-key

# ── escalation-api/.env ─────────────────────────────────────
API_KEY=aiva-escalation-secret-key-2026
ADMIN_BOT_TOKEN=<admin_bot_token>
TRAINER_BOT_TOKEN=<trainer_bot_token>
STAFF_BOT_TOKEN=<staff_bot_token>
STAFF_DIFY_API_KEY=<dify_app_key_for_staff_chatflow>
DIFY_API_BASE_URL=http://host.docker.internal/v1
EXTERNAL_KB_URL=http://host.docker.internal:8000
EXTERNAL_KB_API_KEY=sk-aiva-external-knowledge-secret-key
EXTERNAL_KB_DATASET_ID=<dify_dataset_id>
PORT=8001
ROUTER_API_URL=http://host.docker.internal:20129/v1/chat/completions

# ── dify-9router-proxy/.env ─────────────────────────────────
PROXY_PORT=20129
UPSTREAM_BASE_URL=http://host.docker.internal:20128
FORCE_STREAM_FALSE=true

# ── dify/docker/.env ────────────────────────────────────────
# (xem dify/docker/.env.example để điền đầy đủ)
